{
        "version": 2,
        "name": "phishviz",
        "builds": [
                  {
                              "src": "api/index.py",
                              "use": "@vercel/python",
                              "config": {
                                            "includeFiles": "data/ml/**"
                              }
                  },
                  {
                              "src": "client/package.json",
                              "use": "@vercel/static-build",
                              "config": {
                                            "distDir": "dist"
                              }
                  }
        ],
        "rewrites": [
                  {
                              "source": "/api/(.*)",
                              "destination": "/api/index.py"
                  },
                  {
                              "source": "/assets/(.*)",
                              "destination": "/client/assets/$1"
                  },
                  {
                              "source": "/((?!api/).*)",
                              "destination": "/client/index.html"
                  }
        ]
}
