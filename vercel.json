{
    "version": 2,
    "name": "phishviz",
    "builds": [
          {
                  "src": "api/index.py",
                  "use": "@vercel/python",
                  "config": {
                            "includeFiles": "data/ml/**"
                  }
          },
          {
                  "src": "client/package.json",
                  "use": "@vercel/static-build",
                  "config": {
                            "distDir": "dist"
                  }
          }
    ],
    "rewrites": [
          {
                  "source": "/api/(.*)",
                  "destination": "/api/index.py"
          },
          {
                  "source": "/data/(.*)",
                  "destination": "/client/data/$1"
          },
          {
                  "source": "/assets/(.*)",
                  "destination": "/client/assets/$1"
          },
          {
                  "source": "/((?!api/).*)",
                  "destination": "/client/dist/$1"
          }
    ]
}
